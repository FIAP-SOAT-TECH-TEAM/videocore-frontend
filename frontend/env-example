# ===========================================
# VideoCore Frontend — Environment Variables
# ===========================================
# Copie este arquivo como .env.local e preencha os valores.

# URL base da API REST (ex: https://your-apim.azure-api.net)
NEXT_PUBLIC_API_URL=

# URL do WebSocket STOMP (ex: wss://your-domain.com/ws)
NEXT_PUBLIC_WS_URL=

# AWS Cognito
NEXT_PUBLIC_COGNITO_USER_POOL_ID=
NEXT_PUBLIC_COGNITO_CLIENT_ID=
NEXT_PUBLIC_COGNITO_REGION=us-east-1

# Azure API Management — Subscription Key
NEXT_PUBLIC_APIM_SUBSCRIPTION_KEY=
